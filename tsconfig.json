{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@sdcorejs/nestjs": ["src/index.ts"],
      "@sdcorejs/nestjs/orm": ["src/orm/index.ts"],
      "@sdcorejs/nestjs/context": ["src/context/index.ts"],
      "@sdcorejs/nestjs/tenancy": ["src/tenancy/index.ts"],
      "@sdcorejs/nestjs/audit": ["src/audit/index.ts"],
      "@sdcorejs/nestjs/permission": ["src/permission/index.ts"],
      "@sdcorejs/nestjs/cache": ["src/cache/index.ts"],
      "@sdcorejs/nestjs/http": ["src/http/index.ts"],
      "@sdcorejs/nestjs/jwt": ["src/jwt/index.ts"],
      "@sdcorejs/nestjs/validation": ["src/validation/index.ts"],
      "@sdcorejs/nestjs/queue": ["src/queue/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
